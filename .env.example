# Copy to .env and fill in. Do not commit your real .env.

# ── Operational (safe to set anywhere) ──────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
TABLE_NAME=demoworldfun-messages
BUCKET_NAME=your-inbox-bucket
S3_PREFIX=inbox/
APP_TITLE=inbox

# ── AWS credentials (LOCAL ONLY — leave blank on AWS, use an instance/task role)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Auth: OpenID Connect SSO (Authentik) ────────────────────────────────────
# Create an OAuth2/OpenID provider + application in Authentik, then fill these.
OIDC_DISCOVERY_URL=https://authtime.trevorcombs.com/application/o/<app-slug>/.well-known/openid-configuration
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Must EXACTLY match the redirect URI registered in Authentik:
OIDC_REDIRECT_URI=https://your-app-host/auth/callback
# Optional: comma-separated provider groups allowed in (blank = any user):
OIDC_ALLOWED_GROUPS=
# Signs the local session cookie. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=
# Set true whenever served over HTTPS (marks the session cookie Secure):
SECURE_COOKIES=true

# Set true to run with NO login (local dev, or behind another auth proxy).
# When true, all OIDC_* vars above are ignored.
AUTH_DISABLED=

# ── Compose only ────────────────────────────────────────────────────────────
HOST_PORT=8100
